# .env.example – Kopier denne til .env for lokal utvikling
# NB: Commit ALDRI .env til Git!

# ──────────────────────────────────────────────
# PÅKREVD
# ──────────────────────────────────────────────

# Telegram Bot Token (fra @BotFather)
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram Chat ID (din personlige ID, eller en gruppe/kanal)
# Kjør: python telegram.py for å finne den automatisk
TELEGRAM_CHAT_ID=987654321

# ──────────────────────────────────────────────
# VALGFRITT (standardverdier vises)
# ──────────────────────────────────────────────

# Hvor ofte boten sjekker nyheter (minutter)
POLL_INTERVAL_MINUTES=5

# Prisendring-terskel i USD (varsler ved +/- denne endringen i Brent-pris)
PRICE_ALERT_THRESHOLD=3.0

# Relevansscore-terskel (0–100). Kun artikler over denne sendes
SCORE_THRESHOLD=40

# Maks varsler per kjøring (forhindrer spam)
MAX_ALERTS_PER_RUN=8

# Inkluder Twitter/X via Nitter RSS (true/false)
INCLUDE_NITTER=true

# Sti til data-mappe (for Railway: mount volum på /data og sett til /data)
# DATA_DIR=./data

# Hvor mange dager vi husker sendte artikler
# SEEN_RETENTION_DAYS=7

# Debug-modus: vis scoring-detaljer i logger
# DEBUG_SCORING=false
